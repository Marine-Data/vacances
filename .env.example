# ─────────────────────────────────────────────────────────────────────────────
# Client (exposé au navigateur — protégé par la RLS Supabase). Préfixe VITE_ requis.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# Seed UNIQUEMENT (scripts/seed.ts, exécuté hors app). NE JAMAIS committer / exposer.
# Clé service_role : Dashboard Supabase → Project Settings → API → service_role.
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Mot de passe initial commun des 5 comptes (communiqué hors-bande aux invitées).
SEED_DEFAULT_PASSWORD=change-me
